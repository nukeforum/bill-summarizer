<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      AICore declares minSdk 31; we keep app minSdk at 26 and runtime-gate
      every AICore call (capability check + summarizer) behind Build.VERSION.
      Older devices report NotSupported and the worker never enqueues for
      them, so the API-31 symbols are unreachable at runtime.
    -->
    <uses-sdk tools:overrideLibrary="com.google.ai.edge.aicore" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Android 11+ package visibility filters: declare the LLM apps so
      PackageManager.getPackageInfo and Intent.setPackage can see them, and
      declare ACTION_SEND text/plain so the generic chooser can resolve.
    -->
    <queries>
        <package android:name="com.openai.chatgpt" />
        <package android:name="com.anthropic.claude" />
        <package android:name="com.google.android.apps.bard" />
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>

    <application
        android:name=".InformedCitizenApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:windowSoftInputMode="adjustResize"
        android:theme="@style/Theme.InformedCitizen">
        <!--
          Opt out of WorkManager's default initializer because we supply
          a Configuration.Provider in InformedCitizenApp (HiltWorkerFactory).
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
        <!--
          Default Crashlytics auto-collection to OFF. Programmatic enable
          happens only on release builds when the user has opted in via
          Settings, so any race window before our app code runs is silent.
        -->
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="false" />
        <receiver
            android:name="com.informedcitizen.data.work.StopSummarizationReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.informedcitizen.action.STOP_SUMMARIZATION" />
            </intent-filter>
        </receiver>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.InformedCitizen.Starting"
            tools:ignore="Instantiatable"><!-- Hilt's @AndroidEntryPoint generates a wrapper lint can't see. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
